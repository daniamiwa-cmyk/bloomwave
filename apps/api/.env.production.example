# Production environment variables for Amaia API
# Set these on your hosting provider (Railway, Render, Fly.io, etc.)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

ANTHROPIC_API_KEY=sk-ant-your-production-key
OPENAI_API_KEY=sk-your-production-key

PORT=3000
NODE_ENV=production

# RevenueCat (required in production)
REVENUECAT_SECRET_KEY=sk_your_revenuecat_secret_key
REVENUECAT_WEBHOOK_SECRET=your_webhook_auth_secret

# CORS — comma-separated list of allowed origins
# For a mobile-only app, you can be restrictive
CORS_ORIGIN=https://your-api-domain.com
